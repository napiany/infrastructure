[Unit]
Description=Vaultwarden PostgreSQL

[Container]
ContainerName=vaultwarden-postgres
Image=docker.io/library/postgres:18.3-alpine@sha256:52098013b4b64a746626437d38afc03cabff6cdeb4d3d92e2342aa95f0ce56ea
AutoUpdate=registry

Network=vaultwarden-postgres.network
NetworkAlias=vaultwarden-postgres

Volume=vaultwarden-postgres:/var/lib/postgresql/18/docker:U,Z,noexec
ReadOnly=true
Mount=type=tmpfs,tmpfs-size=50M,tmpfs-mode=0770,U,noexec,nosuid,nodev,destination=/var/run/postgresql

Environment=POSTGRES_USER=vaultwarden
Secret=vaultwarden-postgres_password,type=env,target=POSTGRES_PASSWORD

Memory=1g
PidsLimit=256
PodmanArgs=--cpus=1
User=300004
Group=300004

NoNewPrivileges=true
DropCapability=ALL

HealthCmd=pg_isready -U vaultwarden
HealthInterval=15s
HealthTimeout=5s
Notify=healthy

[Service]
LockPersonality=true
ProtectClock=true
RestrictRealtime=true
RuntimeDirectoryMode=700
SystemCallArchitectures=native
SystemCallFilter=~@obsolete

Restart=always

[Install]
WantedBy=vaultwarden.target
