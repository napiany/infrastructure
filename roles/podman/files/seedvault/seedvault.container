[Unit]
Description=SeedVault WebDAV backups

[Container]
ContainerName=seedvault
Image=seedvault.build

Network=nginx-seedvault.network
NetworkAlias=seedvault

Volume=seedvault-config:/config:ro,Z
Volume=seedvault-data:/data:Z
ReadOnly=true
Mount=type=tmpfs,tmpfs-size=32M,tmpfs-mode=1777,U,noexec,nosuid,nodev,destination=/tmp

Memory=256m
PidsLimit=128
PodmanArgs=--cpus=1
User=300018
Group=300018

NoNewPrivileges=true
DropCapability=ALL

[Service]
LockPersonality=true
ProtectClock=true
RestrictRealtime=true
RuntimeDirectoryMode=700
SystemCallArchitectures=native
SystemCallFilter=~@obsolete
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
