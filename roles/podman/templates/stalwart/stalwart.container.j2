[Unit]
Description=Stalwart
After=stalwart-postgres.service
Wants=stalwart-postgres.service

[Container]
ContainerName=stalwart
Image=ghcr.io/stalwartlabs/stalwart:v0.15.5@sha256:b6c2a04a79695136d5e2c16e9da0254135d0c3f3b1f8147873e812916b0ae8c4
AutoUpdate=registry

Network=haproxy-stalwart.network:ip6={{ podman_haproxy_networks.stalwart.ipv6 }}
Network=stalwart-postgres.network
NetworkAlias=stalwart

Volume=stalwart:/opt/stalwart:U,Z,noexec
Volume=certbot:/etc/letsencrypt:ro,z,noexec
ReadOnly=true
Mount=type=tmpfs,tmpfs-size=64M,tmpfs-mode=1777,U,noexec,nosuid,nodev,destination=/tmp

Secret=stalwart_adminsecret,type=env,target=ADMIN_SECRET
Secret=stalwart-postgres_password,type=env,target=STALWART_POSTGRES_PASSWORD

Memory=1g
PidsLimit=512
PodmanArgs=--cpus=2
User=300006
Group=300006

NoNewPrivileges=true
DropCapability=ALL
AddCapability=NET_BIND_SERVICE

[Service]
LockPersonality=true
ProtectClock=true
RestrictRealtime=true
RuntimeDirectoryMode=700
SystemCallArchitectures=native
SystemCallFilter=~@obsolete
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
