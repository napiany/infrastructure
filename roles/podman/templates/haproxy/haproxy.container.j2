{% set has_ipv6 = ansible_facts["default_ipv6"]["address"] | default("") | length > 0 %}
{% set mail_ports = [25, 465, 587, 993] %}
[Unit]
Description=HAProxy edge proxy
Requires=wg-quick@wg0.service
Wants=crowdsec-spoa.service
After=wg-quick@wg0.service crowdsec-spoa.service

[Container]
ContainerName=haproxy
Image=haproxy.build

Network=haproxy-crowdsec.network
Volume=haproxy-config:/usr/local/etc/haproxy:ro,z,noexec
PublishPort={{ ansible_facts["default_ipv4"]["address"] }}:80:80/tcp
PublishPort={{ ansible_facts["default_ipv4"]["address"] }}:443:443/tcp
{% if has_ipv6 %}
PublishPort=[::]:80:80/tcp
PublishPort=[::]:443:443/tcp
{% endif %}
{% if podman_stalwart_mail_backend | length > 0 %}
{% for port in mail_ports %}
PublishPort={{ ansible_facts["default_ipv4"]["address"] }}:{{ port }}:{{ port }}/tcp
{% endfor %}
{% if has_ipv6 %}
{% for port in mail_ports %}
PublishPort=[::]:{{ port }}:{{ port }}/tcp
{% endfor %}
{% endif %}
{% endif %}
ReadOnly=true
Mount=type=tmpfs,tmpfs-size=1M,tmpfs-mode=0770,U,noexec,nosuid,nodev,destination=/run
Mount=type=tmpfs,tmpfs-size=1M,tmpfs-mode=0770,U,noexec,nosuid,nodev,destination=/tmp

Memory=256m
PidsLimit=256
PodmanArgs=--cpus=2
User=300019
Group=300019

NoNewPrivileges=true
DropCapability=ALL
AddCapability=NET_BIND_SERVICE

[Service]
LockPersonality=true
ProtectClock=true
RestrictRealtime=true
RuntimeDirectoryMode=700
SystemCallArchitectures=native
SystemCallFilter=~@obsolete
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
