{% set has_default_ipv6 = ansible_facts["default_ipv6"]["address"] | default("") | length > 0 %}
{% set stalwart_local_mail_ports = [465, 587, 993] %}
{% set stalwart_wireguard_mail_ports = [25, 465, 587, 993] %}
[Unit]
Description=HAProxy
Requires=wg-quick@wg0.service crowdsec.service crowdsec-spoa.service
After=wg-quick@wg0.service crowdsec.service crowdsec-spoa.service

[Container]
ContainerName=haproxy
Image=haproxy.build
Network=haproxy-ingress.network:ip={{ podman_haproxy_ingress_ipv4 }},ip6={{ podman_haproxy_ingress_ipv6 }}
Network=haproxy-crowdsec.network:ip6={{ podman_haproxy_crowdsec_ipv6 }}
{% if 'kanidm' in podman_containers_selected %}
Network=haproxy-kanidm.network:ip6={{ podman_haproxy_networks.kanidm.proxy_ipv6 }}
{% endif %}
{% if 'vaultwarden' in podman_containers_selected %}
Network=haproxy-vaultwarden.network:ip6={{ podman_haproxy_networks.vaultwarden.proxy_ipv6 }}
{% endif %}
{% if 'seedvault' in podman_containers_selected %}
Network=haproxy-seedvault.network:ip6={{ podman_haproxy_networks.seedvault.proxy_ipv6 }}
{% endif %}
{% if 'ente' in podman_containers_selected %}
Network=haproxy-ente.network:ip6={{ podman_haproxy_networks.ente.proxy_ipv6 }}
{% endif %}
{% if 'stalwart' in podman_containers_selected %}
Network=haproxy-stalwart.network:ip6={{ podman_haproxy_networks.stalwart.proxy_ipv6 }}
{% endif %}
{% if 'autopush' in podman_containers_selected %}
Network=haproxy-autopush.network:ip={{ podman_haproxy_networks.autopush.proxy_ipv4 }}
{% endif %}
{% if 'mollysocket' in podman_containers_selected %}
Network=haproxy-mollysocket.network:ip={{ podman_haproxy_networks.mollysocket.proxy_ipv4 }},ip6={{ podman_haproxy_networks.mollysocket.proxy_ipv6 }}
{% endif %}
{% if 'monitoring' in podman_containers_selected %}
Network=haproxy-prometheus.network:ip6={{ podman_haproxy_networks.prometheus.proxy_ipv6 }}
Network=haproxy-alertmanager.network:ip6={{ podman_haproxy_networks.alertmanager.proxy_ipv6 }}
Network=haproxy-grafana.network:ip6={{ podman_haproxy_networks.grafana.proxy_ipv6 }}
{% endif %}
PublishPort={{ podman_wireguard_ip }}:80:80/tcp
PublishPort=[{{ podman_local_wireguard_ipv6 }}]:80:80/tcp
PublishPort={{ podman_wireguard_ip }}:443:443/tcp
PublishPort=[{{ podman_local_wireguard_ipv6 }}]:443:443/tcp
PublishPort={{ podman_wireguard_ip }}:443:443/udp
PublishPort=[{{ podman_local_wireguard_ipv6 }}]:443:443/udp
{% if podman_local_ingress_ipv6 | length > 0 and podman_local_ingress_ipv6 != podman_local_wireguard_ipv6 %}
PublishPort=[{{ podman_local_ingress_ipv6 }}]:80:80/tcp
PublishPort=[{{ podman_local_ingress_ipv6 }}]:443:443/tcp
PublishPort=[{{ podman_local_ingress_ipv6 }}]:443:443/udp
{% endif %}
{% if 'stalwart' in podman_containers_selected %}
{% for port in stalwart_local_mail_ports %}
PublishPort={{ ansible_facts["default_ipv4"]["address"] }}:{{ port }}:{{ port }}/tcp
{% endfor %}
{% if has_default_ipv6 %}
{% for port in stalwart_local_mail_ports %}
PublishPort=[{{ ansible_facts["default_ipv6"]["address"] }}]:{{ port }}:{{ port }}/tcp
{% endfor %}
{% endif %}
{% if podman_wireguard_ip | default("") | length > 0 %}
{% for port in stalwart_wireguard_mail_ports %}
PublishPort={{ podman_wireguard_ip }}:{{ port }}:{{ port }}/tcp
{% endfor %}
{% endif %}
{% endif %}

Volume=haproxy-config:/usr/local/etc/haproxy:ro,U,z,noexec
Volume=certbot-webroot:/var/www/certbot:ro,z,noexec
ReadOnly=true
Mount=type=tmpfs,tmpfs-size=4M,tmpfs-mode=0770,U,noexec,nosuid,nodev,destination=/run
Mount=type=tmpfs,tmpfs-size=16M,tmpfs-mode=1777,U,noexec,nosuid,nodev,destination=/tmp

Memory=768m
PidsLimit=512
PodmanArgs=--cpus=2
User=300019
Group=300019

NoNewPrivileges=true
DropCapability=ALL
AddCapability=NET_BIND_SERVICE

[Service]
LockPersonality=true
ProtectClock=true
RestrictRealtime=true
RuntimeDirectoryMode=700
SystemCallArchitectures=native
SystemCallFilter=~@obsolete
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
