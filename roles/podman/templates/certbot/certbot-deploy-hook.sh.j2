#!/bin/sh
set -eu

NGINX_UID='300001'
KANIDM_UID='300002'
STALWART_UID='300006'

if [ -z "${RENEWED_LINEAGE:-}" ]; then
    echo "RENEWED_LINEAGE is not set" >&2
    exit 1
fi

domain="$(basename "${RENEWED_LINEAGE}")"
live_dir="/etc/letsencrypt/live/${domain}"

if [ ! -d "${live_dir}" ]; then
    echo "Missing certbot lineage directory for ${domain}" >&2
    exit 1
fi

install -d -o root -g root -m 0755 /etc/letsencrypt/consumers

install -d -o "${NGINX_UID}" -g "${NGINX_UID}" -m 0700     "/etc/letsencrypt/consumers/nginx/${domain}"
install -o "${NGINX_UID}" -g "${NGINX_UID}" -m 0444     "${live_dir}/fullchain.pem"     "/etc/letsencrypt/consumers/nginx/${domain}/fullchain.pem"
install -o "${NGINX_UID}" -g "${NGINX_UID}" -m 0400     "${live_dir}/privkey.pem"     "/etc/letsencrypt/consumers/nginx/${domain}/privkey.pem"
install -o "${NGINX_UID}" -g "${NGINX_UID}" -m 0444     "${live_dir}/chain.pem"     "/etc/letsencrypt/consumers/nginx/${domain}/chain.pem"

{% set certbot_kanidm_domain = ((podman_services | default({})).get('kanidm', {})).get('domain', '') %}
{% set certbot_stalwart_settings = (podman_services | default({})).get('stalwart', {}) %}
{% set certbot_stalwart_certificate_blocks = certbot_stalwart_settings.get('certificate_blocks', [{'domains': certbot_stalwart_settings.get('domains', [])}] if certbot_stalwart_settings.get('domains', []) else []) %}
{% if certbot_kanidm_domain | length > 0 %}
if [ "${domain}" = '{{ certbot_kanidm_domain }}' ]; then
    install -d -o "${KANIDM_UID}" -g "${KANIDM_UID}" -m 0700 /etc/letsencrypt/consumers/kanidm
    install -o "${KANIDM_UID}" -g "${KANIDM_UID}" -m 0444 "${live_dir}/fullchain.pem" /etc/letsencrypt/consumers/kanidm/fullchain.pem
    install -o "${KANIDM_UID}" -g "${KANIDM_UID}" -m 0400 "${live_dir}/privkey.pem" /etc/letsencrypt/consumers/kanidm/privkey.pem
fi
{% endif %}
{% for block in certbot_stalwart_certificate_blocks %}
{% if (block.domains | default([]) | length) > 0 %}
if [ "${domain}" = '{{ block.domains | first }}' ]; then
    install -d -o "${STALWART_UID}" -g "${STALWART_UID}" -m 0700         "/etc/letsencrypt/consumers/stalwart/${domain}"
    install -o "${STALWART_UID}" -g "${STALWART_UID}" -m 0444         "${live_dir}/fullchain.pem"         "/etc/letsencrypt/consumers/stalwart/${domain}/fullchain.pem"
    install -o "${STALWART_UID}" -g "${STALWART_UID}" -m 0400         "${live_dir}/privkey.pem"         "/etc/letsencrypt/consumers/stalwart/${domain}/privkey.pem"
fi
{% endif %}
{% endfor %}
