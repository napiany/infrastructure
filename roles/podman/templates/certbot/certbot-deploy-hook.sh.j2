#!/bin/sh
set -eu

NGINX_UID='300001'
KANIDM_UID='300002'
STALWART_UID='300006'

if [ -z "${RENEWED_LINEAGE:-}" ]; then
    echo "RENEWED_LINEAGE is not set" >&2
    exit 1
fi

domain="$(basename "${RENEWED_LINEAGE}")"
archive_dir="/etc/letsencrypt/archive/${domain}"
live_dir="/etc/letsencrypt/live/${domain}"

if [ ! -d "${archive_dir}" ] || [ ! -d "${live_dir}" ]; then
    echo "Missing certbot lineage directories for ${domain}" >&2
    exit 1
fi

chmod 0711 /etc/letsencrypt /etc/letsencrypt/live /etc/letsencrypt/archive
chmod 0710 "${archive_dir}" "${live_dir}"

setfacl -m "u:${NGINX_UID}:x" /etc/letsencrypt /etc/letsencrypt/live /etc/letsencrypt/archive
setfacl -m "u:${KANIDM_UID}:x" /etc/letsencrypt /etc/letsencrypt/live /etc/letsencrypt/archive
setfacl -m "u:${STALWART_UID}:x" /etc/letsencrypt /etc/letsencrypt/live /etc/letsencrypt/archive

find "${archive_dir}" -maxdepth 1 -type f -name 'privkey*.pem' -exec chmod 0400 '{}' +
find "${archive_dir}" -maxdepth 1 -type f ! -name 'privkey*.pem' -exec chmod 0440 '{}' +

setfacl -m "u:${NGINX_UID}:x" "${archive_dir}" "${live_dir}"
find "${archive_dir}" -maxdepth 1 -type f -exec setfacl -m "u:${NGINX_UID}:r" '{}' +
{% set certbot_kanidm_domain = ((podman_services | default({})).get('kanidm', {})).get('domain', '') %}
{% set certbot_stalwart_settings = (podman_services | default({})).get('stalwart', {}) %}
{% set certbot_stalwart_certificate_blocks = certbot_stalwart_settings.get('certificate_blocks', [{'domains': certbot_stalwart_settings.get('domains', [])}] if certbot_stalwart_settings.get('domains', []) else []) %}
{% if certbot_kanidm_domain | length > 0 %}
if [ "${domain}" = '{{ certbot_kanidm_domain }}' ]; then
    setfacl -m "u:${KANIDM_UID}:x" "${archive_dir}" "${live_dir}"
    find "${archive_dir}" -maxdepth 1 -type f -exec setfacl -m "u:${KANIDM_UID}:r" '{}' +
    install -d -o root -g root -m 0711 /etc/letsencrypt/consumers
    install -d -o "${KANIDM_UID}" -g "${KANIDM_UID}" -m 0700 /etc/letsencrypt/consumers/kanidm
    install -o "${KANIDM_UID}" -g "${KANIDM_UID}" -m 0444 "${live_dir}/fullchain.pem" /etc/letsencrypt/consumers/kanidm/fullchain.pem
    install -o "${KANIDM_UID}" -g "${KANIDM_UID}" -m 0400 "${live_dir}/privkey.pem" /etc/letsencrypt/consumers/kanidm/privkey.pem
fi
{% endif %}
{% for block in certbot_stalwart_certificate_blocks %}
{% if (block.domains | default([]) | length) > 0 %}
if [ "${domain}" = '{{ block.domains | first }}' ]; then
    setfacl -m "u:${STALWART_UID}:x" "${archive_dir}" "${live_dir}"
    find "${archive_dir}" -maxdepth 1 -type f -exec setfacl -m "u:${STALWART_UID}:r" '{}' +
fi
{% endif %}
{% endfor %}
