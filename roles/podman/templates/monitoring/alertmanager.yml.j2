---
global:
  resolve_timeout: '5m'
  smtp_smarthost: 'blizzard.mxrouting.net:465'
  smtp_from: 'alerts@napiany.com'
  smtp_auth_username: 'alerts@napiany.com'
  smtp_auth_password: '{{ monitoring_alertmanager_smtp_password }}'
  smtp_require_tls: true
  smtp_force_implicit_tls: true
  smtp_hello: 'alertmanager.napiany.com'

route:
  receiver: 'email'
  group_by:
    - 'alertname'
    - 'instance'
    - 'severity'
  group_wait: '30s'
  group_interval: '10m'
  repeat_interval: '4h'

inhibit_rules:
  - source_matchers:
      - 'severity = critical'
    target_matchers:
      - 'severity = warning'
    equal:
      - 'alertname'
      - 'instance'

receivers:
  - name: 'email'
    email_configs:
      - to: 'robin@napiany.com'
        send_resolved: true
        require_tls: true
