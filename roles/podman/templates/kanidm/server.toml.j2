version = "2"
bindaddress = "0.0.0.0:8443"
db_path = "/data/kanidm.db"
tls_chain = "/etc/letsencrypt/live/{{ kanidm_domain }}/fullchain.pem"
tls_key = "/etc/letsencrypt/live/{{ kanidm_domain }}/privkey.pem"
domain = "{{ kanidm_domain }}"
origin = "https://{{ kanidm_domain }}"

[online_backup]
path = "/data/kanidm/backups/"
schedule = "00 22 * * *"
