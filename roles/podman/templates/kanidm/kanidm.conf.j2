server {
    listen 443 ssl;
    include snippets/proxy-protocol-listener.conf;
    listen [::]:443 ssl;

    http2 on;

    server_name {{ kanidm_domain }};

    ssl_certificate /etc/letsencrypt/consumers/nginx/{{ kanidm_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/consumers/nginx/{{ kanidm_domain }}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/consumers/nginx/{{ kanidm_domain }}/chain.pem;

    include snippets/universal_paths.conf;
    include snippets/security.conf;
    include snippets/permissions.conf;
    include snippets/cross-origin-security.conf;
    include snippets/proxy.conf;
    include snippets/robots.conf;

    location / {
        set $upstream_kanidm https://10.89.100.2:8443;
        proxy_ssl_name {{ kanidm_domain }};
        proxy_ssl_verify on;
        proxy_pass $upstream_kanidm;
    }
}
