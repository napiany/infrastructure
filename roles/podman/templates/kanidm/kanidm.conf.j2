server {
    listen 443 ssl;
    listen 8443 ssl proxy_protocol;
    listen [::]:443 ssl;

    http2 on;

    server_name {{ kanidm_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ kanidm_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ kanidm_domain }}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/{{ kanidm_domain }}/chain.pem;

    include snippets/universal_paths.conf;
    include snippets/security.conf;
    include snippets/permissions.conf;
    include snippets/cross-origin-security.conf;
    include snippets/proxy.conf;
    include snippets/robots.conf;

    resolver 10.89.100.1 valid=30s ipv6=off;

    location / {
        set $upstream_kanidm https://kanidm:8443;
        proxy_ssl_name {{ kanidm_domain }};
        proxy_ssl_verify on;
        proxy_pass $upstream_kanidm;
    }
}
