[Unit]
Description=CrowdSec security engine

[Container]
ContainerName=crowdsec
Image=docker.io/crowdsecurity/crowdsec:v1.7.6
AutoUpdate=registry
Network=nginx-crowdsec.network
IP=10.89.107.2
NetworkAlias=crowdsec

Volume=crowdsec-config:/etc/crowdsec:z,noexec
Volume=crowdsec-data:/var/lib/crowdsec/data:z,noexec
Volume=nginx-logs:/var/log/nginx:ro,z,noexec
ReadOnly=true
Mount=type=tmpfs,tmpfs-size=16M,tmpfs-mode=1777,U,noexec,nosuid,nodev,destination=/tmp

Environment=TZ=UTC
Environment="COLLECTIONS={{ crowdsec_agent_collections_effective | join(' ') }}"
Environment=DISABLE_LOCAL_API=true
Environment=LOCAL_API_URL={{ crowdsec_lapi_url }}
Environment=AGENT_USERNAME={{ inventory_hostname }}
Secret=crowdsec_agent_password,type=env,target=AGENT_PASSWORD

Memory=512m
PidsLimit=256
PodmanArgs=--cpus=1
User=300020
Group=300020

NoNewPrivileges=true
DropCapability=ALL

[Service]
LockPersonality=true
ProtectClock=true
RestrictRealtime=true
RuntimeDirectoryMode=700
SystemCallArchitectures=native
SystemCallFilter=~@obsolete
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
