[crowdsec]
name=crowdsec
baseurl=https://packagecloud.io/crowdsec/crowdsec/rpm_any/rpm_any/$basearch
repo_gpgcheck=1
gpgcheck=1
enabled=1
gpgkey=file:///etc/pki/rpm-gpg/crowdsec-packagecloud.gpg
       file:///etc/pki/rpm-gpg/crowdsec-crowdsec-EDE2C695EC9A5A5C.pub.gpg
       file:///etc/pki/rpm-gpg/crowdsec-crowdsec-C822EDD6B39954A1.pub.gpg
       file:///etc/pki/rpm-gpg/crowdsec-crowdsec-FED78314A2468CCF.pub.gpg
sslverify=1
sslcacert=/etc/pki/tls/certs/ca-bundle.crt
metadata_expire=3600
